<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- UPDATE THESE FOR EACH POST -->
  <title>POST TITLE HERE — View from the Cheap Seats</title>
  <meta name="description" content="POST DESCRIPTION HERE — one or two sentences max." />
  <link rel="canonical" href="https://jamesdillingham.com/POST-SLUG.html" />
  <!-- Open Graph — update title, description, url for each post -->
  <meta property="og:type" content="article" />
  <meta property="og:title" content="POST TITLE HERE — View from the Cheap Seats" />
  <meta property="og:description" content="POST DESCRIPTION HERE" />
  <meta property="og:url" content="https://jamesdillingham.com/POST-SLUG.html" />
  <meta property="og:image" content="https://jamesdillingham.com/assets/hero.jpg" />
  <meta property="og:site_name" content="View from the Cheap Seats" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="POST TITLE HERE — View from the Cheap Seats" />
  <meta name="twitter:description" content="POST DESCRIPTION HERE" />
  <meta name="twitter:image" content="https://jamesdillingham.com/assets/hero.jpg" />
  <link rel="icon" href="favicon.ico" sizes="any" />
  <link rel="icon" href="favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="css/style.css" />
</head>
<body>

  <header class="site-header" id="site-header"></header>

  <div class="site-wrapper">
    <div class="content-grid">

      <main>
        <article class="post-card">

          <div class="post-meta">
            <!-- UPDATE: date and tag for each post -->
            <span class="post-date">Month DD, YYYY</span>
            <span class="post-tag">Political Analysis</span>
          </div>

          <!-- UPDATE: post title -->
          <h1 class="post-title">POST TITLE HERE</h1>

          <!-- POST BODY: replace everything between these comments -->
          <!-- ===================== POST CONTENT START ===================== -->
          <div class="post-body">

            <p>Your post content goes here.</p>

            <p>You can use paragraphs, headers, blockquotes, and embedded media.</p>

            <blockquote>
              Pull quotes get the red left border treatment.
            </blockquote>

            <!-- Embed video (optional) -->
            <!--
            <div style="margin: 1.5rem 0; aspect-ratio: 16/9;">
              <iframe width="100%" height="100%"
                src="https://www.youtube.com/embed/YOUR_VIDEO_ID"
                frameborder="0" allowfullscreen style="display:block;"></iframe>
            </div>
            -->

          </div>
          <!-- ===================== POST CONTENT END ===================== -->

          <!-- AI Review note -->
          <div class="ai-badge mt-3">
            <span class="ai-icon">🤖</span>
            <span>This post was reviewed by the Swarm AI panel before publishing. The arguments were stress-tested across multiple AI systems for logical consistency and blind spots. All conclusions are Jim's.</span>
          </div>

          <!-- Comments section -->
          <div class="comments-section">
            <h3>Join the conversation</h3>
            <p class="comments-note">You don't have to agree with me. You just have to be civil. I read everything.</p>

            <div class="comment-form">
              <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
              <textarea placeholder="Your thoughts..."></textarea>
              <input type="text" placeholder="Your name" />
              <input type="email" placeholder="Email (not published)" />
              <button class="btn">Post Comment</button>
            </div>

            <div id="comments-list" style="margin-top:2rem;"></div>
          </div>

        </article>

        <!-- Post navigation — UPDATE prev/next links -->
        <div style="display:flex; justify-content:space-between; padding: 1rem 0; font-size:0.85rem;">
          <a href="PREV-POST.html" style="color:var(--muted);">← Previous post</a>
          <a href="archive.html" style="color:var(--muted);">All posts →</a>
        </div>

      </main>

      <aside class="sidebar" id="sidebar"></aside>
    </div>
  </div>

  <footer class="site-footer" id="site-footer"></footer>

  <script src="js/components.js"></script>
  <script>
    renderHeader('');
    renderSidebar();
    renderFooter();
    loadComments('POST-SLUG');  // UPDATE: match your filename without .html
  </script>
</body>
</html>
